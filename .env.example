# ── Proxy configuration ──
PROXY_HOST=127.0.0.1
PROXY_PORT=3001
OSIRIS_URL=http://127.0.0.1:3000

# ── Audit storage ──
DB_PATH=data/audit.db

# ── Authorization gate ──
AUTH_TOKEN_TTL_SECONDS=1800
# Demo admin credentials (DO NOT use in production)
# The admin MUST NOT be named like a demo role (analyst/supervisor/custodian):
# otherwise the seeding skips creating that demo user and the RBAC tests fail on a clean clone.
ADMIN_USER=admin
ADMIN_PASSWORD=demo

# ── Polygon Amoy ──
# Set MOCK_ANCHOR=true to skip real on-chain submission (no faucet required)
MOCK_ANCHOR=true
AMOY_RPC=https://rpc-amoy.polygon.technology
AMOY_CHAIN_ID=80002
# Generated at first run; do NOT commit
ANCHOR_PRIVATE_KEY=
ANCHOR_ADDRESS=
ANCHOR_CONTRACT=
# Anchor cadence
ANCHOR_BATCH_SIZE=100
ANCHOR_BATCH_INTERVAL_SECONDS=300
